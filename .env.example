# Real values go in .env (which is gitignored)

# LLM via an OpenAI-compatible proxy
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-key-here
LLM_MODEL_PRIMARY=openai/gpt-4o-mini
LLM_MODEL_CHEAP=openai/gpt-4o-mini

# Embedding model (sentence-transformers, runs locally)
EMBED_MODEL=intfloat/multilingual-e5-base
EMBED_DIMENSION=768

# pgvector (via docker-compose)
PG_HOST=postgres
PG_PORT=5432
PG_USER=rag
PG_PASSWORD=ragpass
PG_DATABASE=ragdb

# Retrieval parameters
CHUNK_SIZE_WORDS=200
CHUNK_OVERLAP_WORDS=40
TOP_K_DENSE=20
TOP_K_BM25=20
TOP_K_FINAL=5

# Generation
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500

# Rate limiting (per-IP)
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
